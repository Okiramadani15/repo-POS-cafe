{
    "openapi": "3.0.0",
    "info": {
      "title": "POS Cafe API",
      "version": "1.0.0",
      "description": "Dokumentasi API untuk sistem Point of Sale Cafe - PT. Karyabhakti Manunggal"
    },
    "servers": [
      {
        "url": "http://localhost:8080"
      }
    ],
    "components": {
      "securitySchemes": {
        "bearerAuth": {
          "type": "http",
          "scheme": "bearer",
          "bearerFormat": "JWT"
        }
      }
    },
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "paths": {
      "/api/auth/register": {
        "post": {
          "tags": ["Auth"],
          "summary": "Daftar user/kasir baru",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "username": { "type": "string", "example": "okiramadani" },
                    "password": { "type": "string", "example": "password123" },
                    "role": { "type": "string", "example": "kasir" }
                  }
                }
              }
            }
          },
          "responses": {
            "201": { "description": "User berhasil dibuat" },
            "401": { "description": "Unauthorized - Token tidak ditemukan" }
          }
        }
      },
      "/api/auth/login": {
        "post": {
          "tags": ["Auth"],
          "summary": "Login untuk mendapatkan token akses",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "username": { "type": "string", "example": "okiramadani" },
                    "password": { "type": "string", "example": "password123" }
                  }
                }
              }
            }
          },
          "responses": {
            "200": { "description": "Login berhasil, token diberikan" }
          }
        }
      },
      "/api/products": {
        "get": {
          "tags": ["Products"],
          "summary": "Ambil semua daftar menu cafe",
          "parameters": [
            {
              "name": "category",
              "in": "query",
              "schema": { "type": "string" },
              "description": "Filter berdasarkan nama kategori"
            }
          ],
          "responses": {
            "200": { "description": "Berhasil mendapatkan data produk" }
          }
        }
      },
      "/api/orders": {
        "post": {
          "tags": ["Orders"],
          "summary": "Buat pesanan baru (Checkout)",
          "security": [{ "bearerAuth": [] }],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "product_id": { "type": "string", "example": "f5765679-8b25-4074-8df4-d76659f72af7" },
                          "quantity": { "type": "integer", "example": 2 }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "201": { "description": "Order Berhasil Dibuat" },
            "401": { "description": "Unauthorized - Butuh token login" }
          }
        }
      },
      "/api/dashboard/cashier-stats": {
        "get": {
          "tags": ["Dashboard"],
          "summary": "Statistik pendapatan per kasir dengan filter waktu",
          "security": [{ "bearerAuth": [] }],
          "parameters": [
            {
              "name": "period",
              "in": "query",
              "description": "Filter waktu pendapatan",
              "required": false,
              "schema": {
                "type": "string",
                "enum": ["today", "month", "year"],
                "example": "today"
              }
            }
          ],
          "responses": {
            "200": { "description": "Berhasil mengambil data statistik" }
          }
        }
      }
    }
  }